<?xml version="1.0" encoding="utf-8"?>
<!-- Android 11 and below: exclude all app data from full backup.
     The app uses manual SAF JSON export/import for user-controlled backup. -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
</full-backup-content>
